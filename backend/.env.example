# ── GreatAegis AI Gateway ──
# Copy this file to .env and fill in your values

# Application mode: "simulated" (demo/mock data) or "production" (real vLLM/GPU)
APP_MODE=simulated

# Server port
PORT=8060

# ── Fireworks AI Integration ──
# Get your key at https://fireworks.ai/account/api-keys
# Not needed for simulated mode; the key can also be set via the Settings UI
# FIREWORKS_API_KEY=your_fireworks_api_key_here

# ── Settings Password ──
# Set a password to restrict access to the Settings page in the frontend.
# Leave empty for no password protection.
SETTINGS_PASSWORD=

# ── Persistent ML-KEM key (optional but recommended) ──
# 64 bytes as hex (128 hex chars). If unset, an ephemeral key is generated and
# encrypted documents become unreadable after restart.
# GREATAEGIS_MLKEM_SEED=00010203...3f

# ── Persistent ML-DSA-65 signing key (optional but recommended) ──
# 32 bytes as hex (64 hex chars). If unset, an ephemeral key is generated and
# signatures will not verify after restart.
# GREATAEGIS_MLDSA_SEED=00010203...20

# ── Qdrant vector database ──
# Cloud mode: set QDRANT_URL + QDRANT_API_KEY to use Qdrant Cloud.
# Local mode: leave QDRANT_URL empty and set GREATAEGIS_QDRANT_PATH.
# QDRANT_URL=https://your-cluster-url.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key
GREATAEGIS_QDRANT_PATH=../.qdrant_db

# ── vLLM Endpoint (production only) ──
# Single vLLM endpoint for private inference on AMD Instinct GPU
# VLLM_ENDPOINT=http://your-gpu-host:8000/v1/chat/completions
# VLLM_MODEL_NAME=bottlecapai/ThinkingCap-Qwen3.6-27B

# Remote rocm-smi metrics endpoint for GPU telemetry.
# If unset, auto-derived from VLLM_ENDPOINT (same host, port 8001, path /gpu).
# Requires rocm_metrics_server.py running inside the droplet's rocm container.
# ROCM_SMI_URL=http://your-droplet-ip:8001/gpu

# Prometheus-format GPU metrics endpoint (AMD GPU exporter / amd-smi-exporter).
# Used by the DigitalOcean do-agent with --gpu-metrics-path.
# If unset, auto-derived from VLLM_ENDPOINT (same host, port 5000, path /metrics).
# GPU_PROMETHEUS_URL=http://your-droplet-ip:5000/metrics
