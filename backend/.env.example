# ── GreatAegis AI Gateway ──
# Copy this file to .env and fill in your values

# Application mode: "simulated" (demo/mock data) or "production" (real vLLM/GPU)
APP_MODE=simulated

# Server port
PORT=8060

# ── Fireworks AI Integration ──
# Get your key at https://fireworks.ai/account/api-keys
# Not needed for simulated mode; the key can also be set via the Settings UI
# FIREWORKS_API_KEY=your_fireworks_api_key_here

# ── Settings Password ──
# Set a password to restrict access to the Settings page in the frontend.
# Leave empty for no password protection.
SETTINGS_PASSWORD=

# ── Persistent ML-KEM key (optional but recommended) ──
# 64 bytes as hex (128 hex chars). If unset, an ephemeral key is generated and
# encrypted documents become unreadable after restart.
# GREATAEGIS_MLKEM_SEED=00010203...3f

# ── Qdrant vector database ──
# Cloud mode: set QDRANT_URL + QDRANT_API_KEY to use Qdrant Cloud.
# Local mode: leave QDRANT_URL empty and set GREATAEGIS_QDRANT_PATH.
# QDRANT_URL=https://your-cluster-url.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key
GREATAEGIS_QDRANT_PATH=../.qdrant_db

# ── AMD Private GPU Pod (production only) ──
# vLLM endpoints for private inference on AMD Instinct GPUs
# VLLM_MIXTRAL_ENDPOINT=http://amd-pod-01.local:8000/v1/chat/completions
# VLLM_GEMMA_ENDPOINT=http://amd-pod-02.local:8000/v1/chat/completions
