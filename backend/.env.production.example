# ── GreatAegis AI Gateway — Production Deployment ──
# Copy this file to .env and fill in your values.
# WARNING: NEVER commit .env to version control.

# Application mode: set to "production" for live deployment
APP_MODE=production

# Server port
PORT=8060

# ── CORS ──
# Comma-separated list of allowed origins.
# Must include your Vercel frontend URL and localhost for development.
# Example: https://greataegis.vercel.app,http://localhost:3060
GREATAEGIS_CORS_ORIGINS=https://greataegis.vercel.app,http://localhost:3060,http://127.0.0.1:3060

# ── Gateway API Token (shared-secret authentication) ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# When set, ALL /api/v1/ endpoints require "Authorization: Bearer <token>" header.
# The frontend must set VITE_GATEWAY_TOKEN to the same value.
GATEWAY_API_TOKEN=generate-a-random-token-here

# ── Settings Password ──
# Set a STRONG password (min 12 chars) to protect the Settings page.
# Do NOT use "root" or any common password in production.
SETTINGS_PASSWORD=change-me-to-a-strong-password

# ── Fireworks AI Integration ──
# Get your key at https://fireworks.ai/account/api-keys
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ── Persistent ML-KEM key (REQUIRED for production) ──
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
# WARNING: If unset, encrypted documents become unreadable after restart.
GREATAEGIS_MLKEM_SEED=generate-a-random-128-char-hex-string

# ── Persistent ML-DSA-65 signing key (REQUIRED for production) ──
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: If unset, signatures will not verify after restart.
GREATAEGIS_MLDSA_SEED=generate-a-random-64-char-hex-string

# ── Qdrant vector database ──
# Cloud mode: set QDRANT_URL + QDRANT_API_KEY to use Qdrant Cloud.
# Local mode: leave QDRANT_URL empty and set GREATAEGIS_QDRANT_PATH.
# QDRANT_URL=https://your-cluster-url.qdrant.io
# QDRANT_API_KEY=your_qdrant_api_key
GREATAEGIS_QDRANT_PATH=../.qdrant_db

# ── vLLM Endpoint (production only, optional) ──
# Single vLLM endpoint for private inference on AMD Instinct GPU.
# Leave empty if not using private GPU pods.
# VLLM_ENDPOINT=http://your-gpu-host:8000/v1/chat/completions
# VLLM_MODEL_NAME=bottlecapai/ThinkingCap-Qwen3.6-27B

# Remote rocm-smi metrics endpoint for GPU telemetry (optional).
# If unset, auto-derived from VLLM_ENDPOINT (same host, port 8001, path /gpu).
# ROCM_SMI_URL=http://your-gpu-host:8001/gpu

# Prometheus-format GPU metrics endpoint (optional).
# GPU_PROMETHEUS_URL=http://your-gpu-host:5000/metrics
